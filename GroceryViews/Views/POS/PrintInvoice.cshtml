@model GroceryModel.Order
@{
    Layout = null;
}
<!DOCTYPE html>
<html>
<head>
    <title>Invoice #@Model.Id</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @@media print {
            .no-print { display: none; }
            body { background-color: white; padding: 0; }
            .shadow-xl { shadow: none; }
            .border { border: none; }
        }
    </style>
</head>
<body class="bg-slate-50 p-8 font-sans">
    <div class="max-w-2xl mx-auto bg-white p-10 shadow-2xl rounded-3xl border border-slate-100">
        <div class="flex justify-between items-start mb-12">
            <div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tighter mb-2">Kiki Supermarket</h1>
                <p class="text-slate-400 font-medium">123 Market St, Grocery City</p>
                <p class="text-slate-400 font-medium">Tel: (555) 123-4567</p>
                <p class="text-slate-400 font-medium">Email: hello@kikimarket.com</p>
            </div>
            <div class="text-right">
                <div class="bg-emerald-500 text-white px-4 py-2 rounded-xl font-black text-sm mb-4 inline-block">PAID</div>
                <h2 class="text-2xl font-black text-slate-900">INVOICE</h2>
                <p class="text-slate-500 font-bold">#ORD-@Model.Id.ToString("D5")</p>
                <p class="text-slate-400">@Model.OrderDate.ToString("MMM dd, yyyy HH:mm")</p>
            </div>
        </div>

        <div class="mb-10">
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-widest mb-4 border-b border-slate-100 pb-2">Customer Info</h3>
            <p class="font-bold text-slate-800">@(Model.Customer?.Name ?? "Walk-in Customer")</p>
            <p class="text-slate-500 text-sm">Thank you for your business!</p>
        </div>

        <div class="border-t border-b border-slate-100 py-8 mb-10">
            <table class="w-full">
                <thead>
                    <tr class="text-left text-xs font-black text-slate-400 uppercase tracking-widest">
                        <th class="pb-6">Description</th>
                        <th class="pb-6 text-center">Quantity</th>
                        <th class="pb-6 text-right">Price</th>
                        <th class="pb-6 text-right">Amount</th>
                    </tr>
                </thead>
                <tbody class="text-slate-700">
                    @foreach (var item in Model.OrderDetails)
                    {
                        <tr class="border-b border-slate-50 last:border-0">
                            <td class="py-5">
                                <p class="font-bold text-slate-800">@item.Product?.Name</p>
                                <p class="text-xs text-slate-400">SKU: @(item.Product?.Barcode ?? "N/A")</p>
                            </td>
                            <td class="py-5 text-center font-bold">@item.Quantity</td>
                            <td class="py-5 text-right font-medium text-slate-500">$@item.UnitPrice.ToString("F2")</td>
                            <td class="py-5 text-right font-black text-slate-900">$@item.TotalPrice.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex justify-end">
            <div class="w-72 space-y-4">
                <div class="flex justify-between text-slate-400 font-bold">
                    <span>Subtotal</span>
                    <span class="text-slate-700">$@Model.TotalAmount.ToString("F2")</span>
                </div>
                <div class="flex justify-between text-rose-400 font-bold italic">
                    <span>Discount Applied</span>
                    <span>-$@Model.Discount.ToString("F2")</span>
                </div>
                <div class="flex justify-between items-center pt-6 border-t-2 border-slate-900">
                    <span class="text-lg font-black uppercase tracking-tighter text-slate-900">Total Paid</span>
                    <span class="text-3xl font-black text-emerald-600 tracking-tighter tabular-nums">$@Model.FinalAmount.ToString("F2")</span>
                </div>
            </div>
        </div>

        <div class="mt-20 pt-10 border-t border-slate-50 text-center">
            <div class="inline-block p-4 bg-slate-50 rounded-2xl mb-4">
                <svg class="w-12 h-12 text-slate-200" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v2H7a1 1 0 100 2h2v2a1 1 0 102 0v-2h2a1 1 0 100-2h-2V7z" clip-rule="evenodd"></path></svg>
            </div>
            <p class="text-lg font-bold text-slate-800">Kiki Supermarket Loyalty</p>
            <p class="text-slate-400 text-sm max-w-xs mx-auto mt-1">Earn points on every purchase! Present this receipt on your next visit.</p>
        </div>

        <div class="mt-12 flex justify-center gap-4 no-print">
            <button onclick="window.print()" class="flex items-center gap-2 px-8 py-4 bg-slate-900 text-white rounded-2xl font-bold hover:bg-emerald-600 transition-all shadow-xl hover:shadow-emerald-200 active:scale-95">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path strokeLinecap="round" strokeLinejoin="round" strokeWidth="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"></path></svg>
                Print Receipt
            </button>
            <button onclick="window.close()" class="px-8 py-4 bg-slate-100 text-slate-600 rounded-2xl font-bold hover:bg-slate-200 transition-all active:scale-95">
                Close Window
            </button>
        </div>
    </div>
</body>
</html>
